{
  "compilerOptions": {
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ESNext"],
    "outDir": "dist",
    "jsx": "react-jsx",
    "jsxImportSource": "tsprose",
    "types": ["tsprose/jsx", "tsprose/externals", "@erudit-js/prose/raw"]
  },
  "include": ["src/**/*"]
}

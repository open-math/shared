{
  "name": "@open-math/shared",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {},
    "./config": {
      "import": "./dist/config.js",
      "types": "./dist/config.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    },
    "./checks/*": {
      "import": "./dist/checks/*.js",
      "types": "./dist/checks/*.d.ts"
    },
    "./elements/*": {
      "import": "./src/elements/*.ts",
      "types": "./src/elements/*.ts"
    }
  },
  "scripts": {
    "build": "bun tsc --project tsconfig.src.json",
    "test": "bun vitest run",
    "format": "bun prettier --write ."
  },
  "peerDependencies": {
    "erudit": "*",
    "unslash": "*"
  },
  "devDependencies": {
    "erudit": "^4.3.1-dev.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "unslash": "^2.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "mathjs": "^15.1.1"
  }
}
